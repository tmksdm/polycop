# Режим работы.
# true = симуляция, без реальных денег.
# false = будущий LIVE-режим, пока не используем.
DRY_RUN=true

# Alchemy WebSocket endpoint для Polygon Mainnet.
# Настоящий URL храним только в локальном .env, не в Git.
# Пример:
# ALCHEMY_POLYGON_WSS=wss://polygon-mainnet.g.alchemy.com/v2/AAAA...AAAA
ALCHEMY_POLYGON_WSS=

# Путь к локальному конфигу.
# Обычно оставляем так:
CONFIG_PATH=config.json

# Старый способ задать трейдеров через .env пока оставляем для совместимости.
#
# На Этапе 3 основной способ — config.json -> "traders".
# Если в config.json список traders пустой, приложение возьмёт WATCHED_TRADERS отсюда.
#
# Если добавляем адреса, пишем через запятую:
# WATCHED_TRADERS=0x1111111111111111111111111111111111111111,0x2222222222222222222222222222222222222222
WATCHED_TRADERS=

# Путь к зашифрованному файлу с приватным ключом кошелька.
# Сам файл создаётся командой: python manage_key.py encrypt
# В Git он не попадает (папка secrets/ в .gitignore).
WALLET_KEY_FILE=secrets/wallet.key.enc

# --- CLOB (Этап 5) ---

# Адрес CLOB API Polymarket.
# Боевой: https://clob.polymarket.com
# Менять обычно не нужно. Вынесено в .env на случай тестовой сети.
CLOB_HOST=https://clob.polymarket.com

# Адрес смарт-кошелька Polymarket (funder/proxy), где лежат деньги (pUSD).
# EOA-ключ из WALLET_KEY_FILE подписывает сделки, а средства держит этот адрес.
# Понадобится на Этапе 5.4. Сейчас оставляем пустым.
POLYMARKET_FUNDER=

# L2 API-credentials, которые CLOB выдаёт после деривации по подписи кошелька.
# Их МОЖНО сохранить сюда, чтобы не запрашивать заново при каждом запуске.
# Сейчас оставляем пустыми — на Этапе 5.2 мы их получаем "на лету".
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=
