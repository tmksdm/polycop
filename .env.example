# Режим работы.
# true = симуляция, без реальных денег.
# false = будущий LIVE-режим, пока не используем.
DRY_RUN=true

# Alchemy WebSocket endpoint для Polygon Mainnet.
# Настоящий URL храним только в локальном .env, не в Git.
# Пример:
# ALCHEMY_POLYGON_WSS=wss://polygon-mainnet.g.alchemy.com/v2/AAAA...AAAA
ALCHEMY_POLYGON_WSS=

# Список трейдеров, которых хотим отслеживать.
# На Этапе 1 можно оставить пустым:
# WATCHED_TRADERS=
#
# Если позже добавляем адреса, пишем через запятую:
# WATCHED_TRADERS=0x1111111111111111111111111111111111111111,0x2222222222222222222222222222222222222222
WATCHED_TRADERS=
