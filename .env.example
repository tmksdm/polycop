# Пример файла переменных окружения.
# Этот файл безопасно хранить в GitHub, потому что здесь нет реальных секретов.
#
# Позже ты создашь рядом файл .env, но его НЕЛЬЗЯ коммитить.
# .env уже добавлен в .gitignore.

# Alchemy WebSocket endpoint для Polygon Mainnet.
# Реальный API key сюда не вставляем.
ALCHEMY_POLYGON_WSS=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Режим работы:
# DRY_RUN=true  — симуляция, реальные ордера не отправляем.
# DRY_RUN=false — LIVE-режим, только после тестов.
DRY_RUN=true

# Базовые настройки копирования.
DEFAULT_RATIO_PERCENT=1
DEFAULT_MIN_BET_USD=100
DEFAULT_HOURLY_LIMIT_PERCENT=20

# Ценовой диапазон в центах.
MIN_PRICE_CENTS=3
MAX_PRICE_CENTS=97

# Настройки будущего auto-sell.
AUTO_SELL_THRESHOLD_CENTS=99
SELL_MODE=Full
